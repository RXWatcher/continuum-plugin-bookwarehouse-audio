{
  "plugin_id": "continuum.bookwarehouse-audio",
  "version": "1.0.2",
  "checksum": "c722a76f234b583ae600cb81eaaa8fad1b15a1da2962a64f78be39989f4c1b40",
  "continuum_api_version": "v1",
  "category": "Books/Audiobooks",
  "supported_platforms": [
    {
      "os": "linux",
      "arch": "amd64"
    }
  ],
  "capabilities": [
    {
      "type": "http_routes.v1",
      "id": "backend",
      "display_name": "BookWarehouse audio backend",
      "description": "Catalog, cover, and streaming for a BookWarehouse instance."
    },
    {
      "type": "audiobook_backend.v1",
      "id": "default",
      "display_name": "Book Warehouse Audio",
      "description": "Catalog, cover, and streaming source for the Audiobooks portal.",
      "metadata": {
        "audiobook_roles": [
          "library_source"
        ],
        "supports_catalog": true,
        "supports_requests": false,
        "supports_auto_monitoring": false
      }
    }
  ],
  "http_routes": [
    {
      "id": "stream",
      "method": "GET",
      "path": "/api/v1/stream/*",
      "access": "public"
    },
    {
      "id": "cover",
      "method": "GET",
      "path": "/api/v1/cover/*",
      "access": "public"
    },
    {
      "id": "api",
      "method": "*",
      "path": "/api/v1/*",
      "access": "authenticated"
    },
    {
      "id": "admin",
      "method": "GET",
      "path": "/admin",
      "access": "admin",
      "navigable": true,
      "navigation_label": "BookWarehouse Audio",
      "navigation_kind": "admin"
    },
    {
      "id": "admin_sub",
      "method": "GET",
      "path": "/admin/*",
      "access": "admin"
    }
  ],
  "global_config_schema": [
    {
      "key": "database_url",
      "title": "Plugin database URL",
      "description": "PostgreSQL DSN for the BookWarehouse Audio plugin database.",
      "json_schema": "{\"type\":\"object\",\"properties\":{\"value\":{\"type\":\"string\"}},\"required\":[\"value\"]}",
      "required": true,
      "admin_form": {
        "fields": [
          {
            "key": "value",
            "label": "Database URL",
            "control": "ADMIN_FORM_CONTROL_TEXT",
            "required": true
          }
        ]
      }
    }
  ]
}
